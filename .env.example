# Backend - Flask Configuration
FLASK_ENV=production
FLASK_APP=backend/app.py
SECRET_KEY=your-super-secret-key-change-this

# Database - Railway PostgreSQL
# Railway proporciona esto automáticamente como DATABASE_URL
# Para desarrollo local, usar SQLite (automático)
DATABASE_URL=postgresql://user:password@localhost/saas_compras

# Email (opcional, para notificaciones)
EMAIL_REMITENTE=tu@gmail.com
EMAIL_PASSWORD=app-password-de-google

# Port
PORT=5000

# Frontend - React Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_URL_PROD=https://tu-backend-en-railway.railway.app
